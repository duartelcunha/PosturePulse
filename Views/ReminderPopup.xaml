<Window x:Class="PosturePulse.Views.ReminderPopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="380" Height="150"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="True"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <Geometry x:Key="IconPosture">M12 4l-8 8h5v8h6v-8h5z</Geometry>
        <Geometry x:Key="IconWater">M12 2C6 10 4 14 4 17a8 8 0 0016 0c0-3-2-7-8-15z</Geometry>

        <Style x:Key="ChipStyle" TargetType="Button">
            <Setter Property="Cursor"   Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding"  Value="12,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" CornerRadius="8"
                                Background="#20FFFFFF"
                                BorderBrush="#18FFFFFF"
                                BorderThickness="1"
                                Padding="{TemplateBinding Padding}">
                            <TextBlock Text="{TemplateBinding Content}"
                                       Foreground="#90B8DD"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="12"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="Root"
                                                            Storyboard.TargetProperty="Background.Color"
                                                            To="#30FFFFFF" Duration="0:0:0.12"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="Root"
                                                            Storyboard.TargetProperty="Background.Color"
                                                            To="#20FFFFFF" Duration="0:0:0.12"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#10FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DismissStyle" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width"  Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="DismissBg" CornerRadius="14" Background="Transparent">
                            <TextBlock x:Name="DismissGlyph"
                                       Text="✕" Foreground="#40607A"
                                       FontSize="11"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="DismissBg" Property="Background" Value="#20FFFFFF"/>
                                <Setter TargetName="DismissGlyph" Property="Foreground" Value="#A0B8CC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Root with slide-in transform -->
    <Grid RenderTransformOrigin="0.5,0.5">
        <Grid.RenderTransform>
            <TranslateTransform x:Name="PopupTranslate" Y="-12"/>
        </Grid.RenderTransform>

        <!-- Glass card -->
        <Border CornerRadius="18"
                BorderThickness="1"
                Padding="18,14">
            <Border.Background>
                <SolidColorBrush Color="#0A1020" Opacity="0.92"/>
            </Border.Background>
            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#25385A" Offset="0"/>
                    <GradientStop Color="#15202F" Offset="1"/>
                </LinearGradientBrush>
            </Border.BorderBrush>
            <Border.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="24" ShadowDepth="4" Opacity="0.4"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- TOP: icon + text + dismiss -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Icon circle -->
                    <Border x:Name="IconCircle" Grid.Column="0"
                            Width="48" Height="48" CornerRadius="14"
                            VerticalAlignment="Center">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop x:Name="GradStop1" Color="#1A3560" Offset="0"/>
                                <GradientStop x:Name="GradStop2" Color="#1C5090" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Path x:Name="IconPath"
                              Data="{StaticResource IconPosture}"
                              Width="20" Height="20" Stretch="Uniform"
                              HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Path.Fill>
                                <SolidColorBrush x:Name="IconFill" Color="#80BBFF"/>
                            </Path.Fill>
                        </Path>
                    </Border>

                    <!-- Title + message -->
                    <StackPanel Grid.Column="1" Margin="14,0,8,0" VerticalAlignment="Center">
                        <TextBlock x:Name="TitleText"
                                   Foreground="#5A7A9A"
                                   FontFamily="Segoe UI Variable Text, Segoe UI"
                                   FontSize="10.5" FontWeight="SemiBold"
                                   Text="POSTURE REMINDER"/>
                        <TextBlock x:Name="MessageText"
                                   Margin="0,4,0,0"
                                   Foreground="#DCE8F8"
                                   FontFamily="Segoe UI Variable Text, Segoe UI"
                                   FontSize="18" FontWeight="SemiBold"
                                   Text="Straighten up"/>
                    </StackPanel>

                    <!-- Dismiss -->
                    <Button Grid.Column="2"
                            Style="{StaticResource DismissStyle}"
                            VerticalAlignment="Top"
                            Click="Dismiss_Click"/>
                </Grid>

                <!-- BOTTOM: snooze chips -->
                <StackPanel Grid.Row="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,10,0,0">
                    <Button Style="{StaticResource ChipStyle}"
                            Content="Snooze 5 min"
                            Margin="0,0,8,0"
                            Click="Snooze5_Click"/>
                    <Button Style="{StaticResource ChipStyle}"
                            Content="Snooze 15 min"
                            Click="Snooze15_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
