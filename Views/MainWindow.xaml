<Window x:Class="PosturePulse.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="PosturePulse"
        Width="960" Height="680"
        MinWidth="860" MinHeight="580"
        Background="Transparent"
        TextElement.FontFamily="Segoe UI Variable Text, Segoe UI"
        TextElement.FontSize="13"
        TextElement.Foreground="#E2E8F0"
        WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow">

    <WindowChrome.WindowChrome>
        <WindowChrome
            CaptionHeight="44"
            GlassFrameThickness="-1"
            ResizeBorderThickness="6"
            CornerRadius="12"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>

        <!-- PALETTE -->
        <SolidColorBrush x:Key="BgBrush"        Color="#0C0F14"/>
        <SolidColorBrush x:Key="SurfaceBrush"   Color="#14181F"/>
        <SolidColorBrush x:Key="Surface2Brush"  Color="#191E27"/>
        <SolidColorBrush x:Key="ElevBrush"      Color="#1E2430"/>
        <SolidColorBrush x:Key="StrokeBrush"    Color="#1E2636"/>
        <SolidColorBrush x:Key="StrokeHover"    Color="#2A3548"/>
        <SolidColorBrush x:Key="AccentBrush"    Color="#6C9FFF"/>
        <SolidColorBrush x:Key="AccentBright"   Color="#88B4FF"/>
        <SolidColorBrush x:Key="AccentSubtle"   Color="#0E1628"/>
        <SolidColorBrush x:Key="TextPri"        Color="#E2E8F0"/>
        <SolidColorBrush x:Key="TextSec"        Color="#6B7A8D"/>
        <SolidColorBrush x:Key="TextMut"        Color="#3A4555"/>
        <SolidColorBrush x:Key="CyanBrush"      Color="#56D4E0"/>
        <SolidColorBrush x:Key="GreenBrush"     Color="#4ADE80"/>
        <SolidColorBrush x:Key="PurpleBrush"    Color="#A78BFA"/>
        <SolidColorBrush x:Key="AmberBrush"     Color="#FBBF24"/>
        <SolidColorBrush x:Key="AmberDim"       Color="#2A1E08"/>

        <!-- TYPOGRAPHY -->
        <Style x:Key="DisplayStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPri}"/>
            <Setter Property="FontSize"   Value="22"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="TitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPri}"/>
            <Setter Property="FontSize"   Value="13.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="CaptionStyle" TargetType="TextBlock">
            <Setter Property="Foreground"   Value="{StaticResource TextSec}"/>
            <Setter Property="FontSize"     Value="12"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="LineHeight"   Value="18"/>
        </Style>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSec}"/>
            <Setter Property="FontSize"   Value="10.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- CARD -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background"      Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource StrokeBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="16"/>
            <Setter Property="Padding"         Value="22,20"/>
            <Setter Property="Margin"          Value="0,0,0,12"/>
        </Style>

        <!-- VALUE PILL -->
        <Style x:Key="ValuePillStyle" TargetType="Border">
            <Setter Property="Background"   Value="{StaticResource AccentSubtle}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding"      Value="10,4"/>
        </Style>
        <Style x:Key="ValuePillTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
            <Setter Property="FontSize"   Value="11.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- TOGGLE SWITCH -->
        <Style x:Key="ToggleStyle" TargetType="CheckBox">
            <Setter Property="Cursor"     Value="Hand"/>
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource TextPri}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <BulletDecorator Background="Transparent" VerticalAlignment="Center">
                            <BulletDecorator.Bullet>
                                <Border x:Name="TrackBorder" Width="42" Height="24" CornerRadius="12">
                                    <Border.Background>
                                        <SolidColorBrush x:Name="TrackFill" Color="#1E2636"/>
                                    </Border.Background>
                                    <Canvas Width="42" Height="24" ClipToBounds="True">
                                        <Ellipse x:Name="ThumbDot" Width="16" Height="16"
                                                 Canvas.Left="4" Canvas.Top="4">
                                            <Ellipse.Fill>
                                                <SolidColorBrush x:Name="ThumbFill" Color="#4A5568"/>
                                            </Ellipse.Fill>
                                        </Ellipse>
                                    </Canvas>
                                </Border>
                            </BulletDecorator.Bullet>
                            <ContentPresenter Margin="10,0,0,0" VerticalAlignment="Center"/>
                        </BulletDecorator>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ThumbDot"
                                                Storyboard.TargetProperty="(Canvas.Left)"
                                                To="22" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <ColorAnimation Storyboard.TargetName="TrackFill" Storyboard.TargetProperty="Color" To="#6C9FFF" Duration="0:0:0.15"/>
                                            <ColorAnimation Storyboard.TargetName="ThumbFill" Storyboard.TargetProperty="Color" To="#FFFFFF" Duration="0:0:0.1"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ThumbDot"
                                                Storyboard.TargetProperty="(Canvas.Left)"
                                                To="4" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <ColorAnimation Storyboard.TargetName="TrackFill" Storyboard.TargetProperty="Color" To="#1E2636" Duration="0:0:0.15"/>
                                            <ColorAnimation Storyboard.TargetName="ThumbFill" Storyboard.TargetProperty="Color" To="#4A5568" Duration="0:0:0.1"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TrackBorder" Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- SLIDER -->
        <Style x:Key="SliderStyle" TargetType="Slider">
            <Setter Property="Height" Value="24"/>
            <Setter Property="Margin" Value="0,8,0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid Height="24" VerticalAlignment="Center">
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge" Focusable="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="4" VerticalAlignment="Center" CornerRadius="2" Background="#6C9FFF"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge" Focusable="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="4" VerticalAlignment="Center" CornerRadius="2" Background="#1A2030"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="18" Height="18">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Grid>
                                                    <Ellipse x:Name="GlowRing" Width="26" Height="26" Opacity="0">
                                                        <Ellipse.Fill>
                                                            <RadialGradientBrush>
                                                                <GradientStop Color="#306C9FFF" Offset="0.4"/>
                                                                <GradientStop Color="#006C9FFF" Offset="1"/>
                                                            </RadialGradientBrush>
                                                        </Ellipse.Fill>
                                                    </Ellipse>
                                                    <Ellipse x:Name="ThumbCircle" Width="16" Height="16" Fill="#D0DCEC">
                                                        <Ellipse.Effect>
                                                            <DropShadowEffect Color="#000000" BlurRadius="6" ShadowDepth="0" Opacity="0.25"/>
                                                        </Ellipse.Effect>
                                                    </Ellipse>
                                                </Grid>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Trigger.EnterActions>
                                                            <BeginStoryboard><Storyboard>
                                                                <DoubleAnimation Storyboard.TargetName="GlowRing" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.15"/>
                                                                <ColorAnimation Storyboard.TargetName="ThumbCircle" Storyboard.TargetProperty="Fill.Color" To="#FFFFFF" Duration="0:0:0.15"/>
                                                            </Storyboard></BeginStoryboard>
                                                        </Trigger.EnterActions>
                                                        <Trigger.ExitActions>
                                                            <BeginStoryboard><Storyboard>
                                                                <DoubleAnimation Storyboard.TargetName="GlowRing" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.2"/>
                                                                <ColorAnimation Storyboard.TargetName="ThumbCircle" Storyboard.TargetProperty="Fill.Color" To="#D0DCEC" Duration="0:0:0.2"/>
                                                            </Storyboard></BeginStoryboard>
                                                        </Trigger.ExitActions>
                                                    </Trigger>
                                                    <Trigger Property="IsDragging" Value="True">
                                                        <Setter TargetName="ThumbCircle" Property="Fill" Value="#6C9FFF"/>
                                                        <Setter TargetName="ThumbCircle" Property="Width" Value="18"/>
                                                        <Setter TargetName="ThumbCircle" Property="Height" Value="18"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TEXTBOX -->
        <Style x:Key="TextBoxStyle" TargetType="TextBox">
            <Setter Property="Background"     Value="Transparent"/>
            <Setter Property="Foreground"     Value="{StaticResource TextPri}"/>
            <Setter Property="CaretBrush"     Value="{StaticResource AccentBrush}"/>
            <Setter Property="SelectionBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="FontSize"       Value="14"/>
            <Setter Property="Margin"         Value="0,6,0,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Grid>
                            <Border x:Name="FocusLine" VerticalAlignment="Bottom" BorderThickness="0,0,0,1" BorderBrush="#2A3548"/>
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="False" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden" Padding="0,8,0,8"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="FocusLine" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                <Setter TargetName="FocusLine" Property="BorderThickness" Value="0,0,0,2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- PRIMARY BUTTON -->
        <Style x:Key="PrimaryBtnStyle" TargetType="Button">
            <Setter Property="Cursor"     Value="Hand"/>
            <Setter Property="FontSize"   Value="12.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#0C0F14"/>
            <Setter Property="Padding"    Value="16,9"/>
            <Setter Property="Margin"     Value="0,0,8,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" CornerRadius="10" Background="#6C9FFF" Padding="{TemplateBinding Padding}">
                            <Border.Effect>
                                <DropShadowEffect Color="#6C9FFF" BlurRadius="14" ShadowDepth="0" Opacity="0.2"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions><BeginStoryboard><Storyboard>
                                    <ColorAnimation Storyboard.TargetName="Root" Storyboard.TargetProperty="Background.Color" To="#88B4FF" Duration="0:0:0.12"/>
                                </Storyboard></BeginStoryboard></Trigger.EnterActions>
                                <Trigger.ExitActions><BeginStoryboard><Storyboard>
                                    <ColorAnimation Storyboard.TargetName="Root" Storyboard.TargetProperty="Background.Color" To="#6C9FFF" Duration="0:0:0.12"/>
                                </Storyboard></BeginStoryboard></Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#4A80E0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- GHOST BUTTON -->
        <Style x:Key="GhostBtnStyle" TargetType="Button">
            <Setter Property="Cursor"     Value="Hand"/>
            <Setter Property="FontSize"   Value="12.5"/>
            <Setter Property="Foreground" Value="{StaticResource TextPri}"/>
            <Setter Property="Padding"    Value="16,9"/>
            <Setter Property="Margin"     Value="0,0,8,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" CornerRadius="10" Background="#14181F" BorderBrush="#1E2636" BorderThickness="1" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions><BeginStoryboard><Storyboard>
                                    <ColorAnimation Storyboard.TargetName="Root" Storyboard.TargetProperty="Background.Color" To="#1C2230" Duration="0:0:0.12"/>
                                    <ColorAnimation Storyboard.TargetName="Root" Storyboard.TargetProperty="BorderBrush.Color" To="#2A3548" Duration="0:0:0.12"/>
                                </Storyboard></BeginStoryboard></Trigger.EnterActions>
                                <Trigger.ExitActions><BeginStoryboard><Storyboard>
                                    <ColorAnimation Storyboard.TargetName="Root" Storyboard.TargetProperty="Background.Color" To="#14181F" Duration="0:0:0.12"/>
                                    <ColorAnimation Storyboard.TargetName="Root" Storyboard.TargetProperty="BorderBrush.Color" To="#1E2636" Duration="0:0:0.12"/>
                                </Storyboard></BeginStoryboard></Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#10141C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- CAPTION BUTTON (min/max) -->
        <Style x:Key="CaptionBtnStyle" TargetType="Button">
            <Setter Property="Width" Value="44"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="#6B7A8D"/>
            <Setter Property="FontFamily" Value="Segoe Fluent Icons, Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="Transparent" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#18202C"/>
                                <Setter Property="Foreground" Value="#A0B0C0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#0E1420"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CloseBtnStyle" TargetType="Button" BasedOn="{StaticResource CaptionBtnStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="Transparent" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#C42B1C"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#B22A1C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- SLIM SCROLLBAR -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                            <Track.Thumb>
                                <Thumb>
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Border CornerRadius="3" Background="#2A3548" Margin="1"/>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                        </Track>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ICON PATHS -->
        <Geometry x:Key="IconPosture">M12 4l-8 8h5v8h6v-8h5z</Geometry>
        <Geometry x:Key="IconWater">M12 2C6 10 4 14 4 17a8 8 0 0016 0c0-3-2-7-8-15z</Geometry>
        <Geometry x:Key="IconSound">M3 9v6h4l5 5V4L7 9H3zm13.5 3A4.5 4.5 0 0014 8v8a4.47 4.47 0 002.5-4z</Geometry>
        <Geometry x:Key="IconQuiet">M12 3a9 9 0 109 9c0-5-4-9-9-9z</Geometry>
        <Geometry x:Key="IconPause">M6 4h4v16H6zm8 0h4v16h-4z</Geometry>
        <Geometry x:Key="IconBolt">M13 2L3 14h7l-1 8 10-12h-7z</Geometry>

    </Window.Resources>

    <!-- WINDOW CONTENT -->
    <Border x:Name="RootBorder" Background="#E8080D15" CornerRadius="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- CUSTOM TITLE BAR -->
            <Grid Grid.Row="0" Margin="14,0,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="18" Height="18" CornerRadius="5" VerticalAlignment="Center" Margin="0,0,8,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#5080E0" Offset="0"/>
                                <GradientStop Color="#6C9FFF" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="P" Foreground="#0C0F14" FontSize="10" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="PosturePulse" FontSize="12" FontWeight="SemiBold"
                               Foreground="#6B7A8D" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Top">
                    <Button Style="{StaticResource CaptionBtnStyle}" Content="&#xE921;" Click="Minimize_Click"/>
                    <Button x:Name="MaxRestoreBtn" Style="{StaticResource CaptionBtnStyle}" Content="&#xE922;" Click="MaxRestore_Click"/>
                    <Button Style="{StaticResource CloseBtnStyle}" Content="&#xE8BB;" Click="Close_Click"/>
                </StackPanel>
            </Grid>

            <!-- MAIN CONTENT -->
            <Grid Grid.Row="1" Margin="16,0,16,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.2*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="1.4*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT COLUMN -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,0,4,0">
                    <StackPanel>

                        <!-- HERO CARD -->
                        <Border Style="{StaticResource CardStyle}">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#111828" Offset="0"/>
                                    <GradientStop Color="#0E1420" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Width="34" Height="34" CornerRadius="10" VerticalAlignment="Center" Margin="0,0,12,0">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#4070D0" Offset="0"/>
                                                <GradientStop Color="#6C9FFF" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <Border.Effect>
                                            <DropShadowEffect Color="#6C9FFF" BlurRadius="16" ShadowDepth="0" Opacity="0.3"/>
                                        </Border.Effect>
                                        <TextBlock Text="P" Foreground="White" FontSize="16" FontWeight="Bold"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Style="{StaticResource DisplayStyle}" Text="PosturePulse" VerticalAlignment="Center"/>
                                </StackPanel>

                                <TextBlock Style="{StaticResource CaptionStyle}" Margin="0,8,0,0"
                                           Text="Stay straight, stay hydrated — with soft reminders that don't break your flow."/>

                                <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                                    <Button Style="{StaticResource PrimaryBtnStyle}" Click="TestPosture_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <Path Data="{StaticResource IconPosture}" Fill="#0C0F14" Width="14" Height="14" Stretch="Uniform" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="Test posture" VerticalAlignment="Center" FontSize="12.5" FontWeight="SemiBold"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource GhostBtnStyle}" Click="TestWater_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <Path Data="{StaticResource IconWater}" Fill="{StaticResource CyanBrush}" Width="13" Height="13" Stretch="Uniform" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="Test water" VerticalAlignment="Center" FontSize="12.5"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource GhostBtnStyle}" Content="Hide to tray" Click="HideToTray_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- SNOOZE BANNER -->
                        <Border x:Name="SnoozeBanner" Visibility="Collapsed" CornerRadius="12"
                                Background="{StaticResource AmberDim}" BorderBrush="#3A2808"
                                BorderThickness="1" Padding="16,10" Margin="0,0,0,12">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource IconPause}" Fill="{StaticResource AmberBrush}"
                                      Width="14" Height="14" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <TextBlock x:Name="SnoozeBannerText" Foreground="{StaticResource AmberBrush}"
                                           FontSize="12.5" VerticalAlignment="Center" Text="Paused"/>
                                <Button Content="Resume now" Margin="14,0,0,0" Click="Resume_Click"
                                        Style="{StaticResource GhostBtnStyle}" Padding="10,5"/>
                            </StackPanel>
                        </Border>

                        <!-- POSTURE CARD -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <Border Width="4" Height="18" CornerRadius="2" VerticalAlignment="Center" Margin="0,0,10,0">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Color="#88B4FF" Offset="0"/>
                                                <GradientStop Color="#6C9FFF" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>
                                    <Path Data="{StaticResource IconPosture}" Fill="{StaticResource AccentBrush}"
                                          Width="15" Height="15" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Style="{StaticResource TitleStyle}" Text="Posture reminder"/>
                                </StackPanel>
                                <TextBlock Style="{StaticResource CaptionStyle}" Text="A soft nudge to sit tall — arrives on every monitor without cutting your focus."/>
                                <CheckBox Style="{StaticResource ToggleStyle}" IsChecked="{Binding PostureEnabled}" Content="Enabled" Margin="0,16,0,0"/>
                                <TextBlock Style="{StaticResource LabelStyle}" Text="REMINDER TEXT" Margin="0,18,0,0"/>
                                <TextBox Style="{StaticResource TextBoxStyle}" Text="{Binding PostureMessage, UpdateSourceTrigger=LostFocus}"/>
                                <Grid Margin="0,20,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource LabelStyle}" Text="REPEAT EVERY" VerticalAlignment="Center"/>
                                    <Border Grid.Column="1" Style="{StaticResource ValuePillStyle}">
                                        <TextBlock Style="{StaticResource ValuePillTextStyle}" Text="{Binding PostureIntervalMinutes, StringFormat={}{0} min}"/>
                                    </Border>
                                </Grid>
                                <Slider Style="{StaticResource SliderStyle}" Minimum="10" Maximum="120" TickFrequency="5" IsSnapToTickEnabled="True" Value="{Binding PostureIntervalMinutes}"/>
                                <TextBlock x:Name="PostureCountdownText" Style="{StaticResource CaptionStyle}" Foreground="{StaticResource TextMut}" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- WATER CARD -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <Border Width="4" Height="18" CornerRadius="2" VerticalAlignment="Center" Margin="0,0,10,0">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Color="#70E0F0" Offset="0"/>
                                                <GradientStop Color="#56D4E0" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>
                                    <Path Data="{StaticResource IconWater}" Fill="{StaticResource CyanBrush}"
                                          Width="15" Height="15" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Style="{StaticResource TitleStyle}" Text="Water reminder"/>
                                </StackPanel>
                                <TextBlock Style="{StaticResource CaptionStyle}" Text="Stay hydrated without overthinking it — an independent timer keeps track for you."/>
                                <CheckBox Style="{StaticResource ToggleStyle}" IsChecked="{Binding WaterEnabled}" Content="Enabled" Margin="0,16,0,0"/>
                                <TextBlock Style="{StaticResource LabelStyle}" Text="REMINDER TEXT" Margin="0,18,0,0"/>
                                <TextBox Style="{StaticResource TextBoxStyle}" Text="{Binding WaterMessage, UpdateSourceTrigger=LostFocus}"/>
                                <Grid Margin="0,20,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource LabelStyle}" Text="REPEAT EVERY" VerticalAlignment="Center"/>
                                    <Border Grid.Column="1" Style="{StaticResource ValuePillStyle}">
                                        <TextBlock Style="{StaticResource ValuePillTextStyle}" Text="{Binding WaterIntervalMinutes, StringFormat={}{0} min}"/>
                                    </Border>
                                </Grid>
                                <Slider Style="{StaticResource SliderStyle}" Minimum="15" Maximum="240" TickFrequency="15" IsSnapToTickEnabled="True" Value="{Binding WaterIntervalMinutes}"/>
                                <TextBlock x:Name="WaterCountdownText" Style="{StaticResource CaptionStyle}" Foreground="{StaticResource TextMut}" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

                <!-- RIGHT COLUMN -->
                <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>

                        <!-- SOUND CARD -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Border Width="4" Height="18" CornerRadius="2" VerticalAlignment="Center" Margin="0,0,10,0">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Color="#BFA0FF" Offset="0"/><GradientStop Color="#A78BFA" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>
                                    <Path Data="{StaticResource IconSound}" Fill="{StaticResource PurpleBrush}" Width="15" Height="15" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Style="{StaticResource TitleStyle}" Text="Sound"/>
                                </StackPanel>
                                <TextBlock Style="{StaticResource CaptionStyle}" Text="Soft chime, short popup, no noise."/>
                                <CheckBox Style="{StaticResource ToggleStyle}" IsChecked="{Binding SoundEnabled}" Content="Enable chime" Margin="0,14,0,0"/>
                                <Grid Margin="0,16,0,0">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource LabelStyle}" Text="VOLUME" VerticalAlignment="Center"/>
                                    <Border Grid.Column="1" Style="{StaticResource ValuePillStyle}">
                                        <TextBlock Style="{StaticResource ValuePillTextStyle}" Text="{Binding SoundVolume, StringFormat={}{0:0}%}"/>
                                    </Border>
                                </Grid>
                                <Slider Style="{StaticResource SliderStyle}" Minimum="0" Maximum="100" TickFrequency="5" IsSnapToTickEnabled="True" Value="{Binding SoundVolume}"/>
                                <Grid Margin="0,14,0,0">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource LabelStyle}" Text="POPUP DURATION" VerticalAlignment="Center"/>
                                    <Border Grid.Column="1" Style="{StaticResource ValuePillStyle}">
                                        <TextBlock Style="{StaticResource ValuePillTextStyle}" Text="{Binding PopupDurationSeconds, StringFormat={}{0} sec}"/>
                                    </Border>
                                </Grid>
                                <Slider Style="{StaticResource SliderStyle}" Minimum="2" Maximum="10" TickFrequency="1" IsSnapToTickEnabled="True" Value="{Binding PopupDurationSeconds}"/>
                                <Separator Margin="0,16" Background="#1E2636" Height="1"/>
                                <CheckBox Style="{StaticResource ToggleStyle}" IsChecked="{Binding StartWithWindows}" Content="Launch on startup"/>
                            </StackPanel>
                        </Border>

                        <!-- QUIET HOURS CARD -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Border Width="4" Height="18" CornerRadius="2" VerticalAlignment="Center" Margin="0,0,10,0">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Color="#6AE080" Offset="0"/><GradientStop Color="#4ADE80" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>
                                    <Path Data="{StaticResource IconQuiet}" Fill="{StaticResource GreenBrush}" Width="14" Height="14" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Style="{StaticResource TitleStyle}" Text="Quiet hours"/>
                                </StackPanel>
                                <TextBlock Style="{StaticResource CaptionStyle}" Text="Suppress all reminders during a daily window — handles overnight spans."/>
                                <CheckBox Style="{StaticResource ToggleStyle}" IsChecked="{Binding QuietHoursEnabled}" Content="Enable quiet hours" Margin="0,14,0,0"/>
                                <Grid Margin="0,16,0,0">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource LabelStyle}" Text="START" VerticalAlignment="Center"/>
                                    <Border Grid.Column="1" Style="{StaticResource ValuePillStyle}">
                                        <TextBlock Style="{StaticResource ValuePillTextStyle}" Text="{Binding QuietHoursStartHour, StringFormat={}{0:D2}:00}"/>
                                    </Border>
                                </Grid>
                                <Slider Style="{StaticResource SliderStyle}" Minimum="0" Maximum="23" TickFrequency="1" IsSnapToTickEnabled="True" Value="{Binding QuietHoursStartHour}"/>
                                <Grid Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource LabelStyle}" Text="END" VerticalAlignment="Center"/>
                                    <Border Grid.Column="1" Style="{StaticResource ValuePillStyle}">
                                        <TextBlock Style="{StaticResource ValuePillTextStyle}" Text="{Binding QuietHoursEndHour, StringFormat={}{0:D2}:00}"/>
                                    </Border>
                                </Grid>
                                <Slider Style="{StaticResource SliderStyle}" Minimum="0" Maximum="23" TickFrequency="1" IsSnapToTickEnabled="True" Value="{Binding QuietHoursEndHour}"/>
                                <TextBlock x:Name="QuietHoursHint" Style="{StaticResource CaptionStyle}" Margin="0,10,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- QUICK ACTIONS CARD -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Border Width="4" Height="18" CornerRadius="2" VerticalAlignment="Center" Margin="0,0,10,0">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Color="#FCD34D" Offset="0"/><GradientStop Color="#FBBF24" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>
                                    <Path Data="{StaticResource IconBolt}" Fill="{StaticResource AmberBrush}" Width="14" Height="14" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Style="{StaticResource TitleStyle}" Text="Quick actions"/>
                                </StackPanel>
                                <TextBlock Style="{StaticResource CaptionStyle}" Text="Pause all reminders without fully disabling the app."/>
                                <WrapPanel Margin="0,14,0,0">
                                    <Button Style="{StaticResource GhostBtnStyle}" Content="Pause 15 min" Padding="12,8" Margin="0,0,6,6" Click="Pause15_Click"/>
                                    <Button Style="{StaticResource GhostBtnStyle}" Content="Pause 30 min" Padding="12,8" Margin="0,0,6,6" Click="Pause30_Click"/>
                                    <Button Style="{StaticResource GhostBtnStyle}" Content="Pause 1 hour" Padding="12,8" Margin="0,0,6,6" Click="Pause60_Click"/>
                                    <Button Style="{StaticResource PrimaryBtnStyle}" Content="Resume" Padding="12,8" Margin="0,0,0,6" Click="Resume_Click"/>
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <!-- NOTES CARD -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource LabelStyle}" Text="NOTES" Margin="0,0,0,8"/>
                                <TextBlock Style="{StaticResource CaptionStyle}" Foreground="#3A4555">
                                    Appears on every monitor. Works over regular apps and borderless-windowed games.
                                    Exclusive fullscreen (D3D exclusive) is not guaranteed without a more invasive overlay.
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Border>
</Window>
